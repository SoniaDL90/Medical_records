    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{--navy:#0a1628;--teal:#0d9488;--teal-light:#14b8a6;--blue:#1d4ed8;--gray:#94a3b8;--gray-light:#e2e8f0;--sidebar-w:260px}
        body{font-family:'DM Sans',sans-serif;background:#f1f5f9;min-height:100vh;display:flex}
        .sidebar{width:var(--sidebar-w);background:var(--navy);min-height:100vh;display:flex;flex-direction:column;position:fixed;top:0;left:0}
