        .sidebar-logo{padding:1.75rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:.875rem}
        .logo-box{width:38px;height:38px;background:linear-gradient(135deg,var(--teal),var(--blue));border-radius:10px;display:flex;align-items:center;justify-content:center}
        .logo-box svg{width:22px;height:22px;fill:white}
        .logo-text{font-family:'DM Serif Display',serif;font-size:1.3rem;color:white}
        .logo-text span{color:var(--teal-light)}
        .nav{flex:1;padding:1rem .75rem}
        .nav-label{color:var(--gray);font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;padding:.5rem .75rem;margin-top:.5rem}
        .nav-item{display:flex;align-items:center;gap:.75rem;padding:.7rem .875rem;border-radius:8px;color:var(--gray);text-decoration:none;font-size:.875rem;transition:all .2s;margin-bottom:2px}
        .nav-item:hover{background:rgba(255,255,255,0.06);color:white}
        .nav-item.active{background:rgba(13,148,136,0.15);color:var(--teal-light)}
        .nav-item svg{width:18px;height:18px;flex-shrink:0}
        .nav-logout{padding:1rem .75rem;border-top:1px solid rgba(255,255,255,0.06)}
        .btn-logout{display:flex;align-items:center;gap:.75rem;width:100%;padding:.7rem .875rem;border-radius:8px;color:#f87171;text-decoration:none;font-size:.875rem;background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}
        .btn-logout:hover{background:rgba(239,68,68,0.1)}
        .btn-logout svg{width:18px;height:18px}
        .main{margin-left:var(--sidebar-w);flex:1;padding:2rem}
        .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem}
        .page-header h1{font-family:'DM Serif Display',serif;font-size:1.875rem;color:var(--navy)}
        .page-header p{color:var(--gray);font-size:.9rem;margin-top:.25rem}
        .role-banner{background:linear-gradient(135deg,var(--navy),#1e3a5f);border-radius:12px;padding:1rem 1.5rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:.75rem;color:white;font-size:.875rem}
        .role-banner svg{width:18px;height:18px;color:var(--teal-light);flex-shrink:0}
        .empty-state{background:white;border-radius:16px;padding:4rem;text-align:center;border:1px solid var(--gray-light)}
        .empty-icon{width:64px;height:64px;background:#f0fdfa;border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;color:var(--teal)}
        .empty-icon svg{width:32px;height:32px}
        .empty-state h3{font-family:'DM Serif Display',serif;font-size:1.5rem;color:var(--navy);margin-bottom:.5rem}
        .empty-state p{color:var(--gray);font-size:.9rem}
