<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Registros Médicos</title>
</head>
<body>
    <h1>Registros Médicos</h1>

    <a href="{{ path('app_dashboard') }}">Volver al Dashboard</a>

    {% if records is empty %}
        <p>No hay registros médicos.</p>
    {% else %}
        <table border="1">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Paciente</th>
                    <th>Doctor</th>
                    <th>Diagnóstico</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for record in records %}
                <tr>
                    <td>{{ record.id }}</td>
                    <td>{{ record.patient.firstName }} {{ record.patient.lastName }}</td>
                    <td>{{ record.doctor.name }}</td>
                    <td>{{ record.diagnosis|slice(0, 50) }}...</td>
                    <td>{{ record.createdAt|date('d/m/Y') }}</td>
                    <td>
                        <a href="{{ path('medical_record_show', {id: record.id}) }}">Ver</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</body>
</html>
