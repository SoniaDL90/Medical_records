        table{width:100%;border-collapse:collapse}
        thead{background:#f8fafc;border-bottom:1px solid var(--gray-light)}
        th{padding:1rem 1.25rem;text-align:left;font-size:.75rem;font-weight:600;color:var(--gray);text-transform:uppercase;letter-spacing:.08em}
        td{padding:1rem 1.25rem;font-size:.875rem;color:#334155;border-bottom:1px solid #f1f5f9}
        tr:last-child td{border-bottom:none}
        tr:hover td{background:#f8fafc}
        .btn-ver{display:inline-flex;align-items:center;gap:.35rem;background:rgba(13,148,136,0.1);color:var(--teal);border:none;border-radius:6px;padding:.35rem .75rem;font-size:.8rem;font-weight:500;text-decoration:none;cursor:pointer;transition:all .2s}
        .btn-ver:hover{background:rgba(13,148,136,0.2)}
        .restricted{color:var(--gray);font-style:italic;font-size:.8rem}
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-box">
                <svg viewBox="0 0 24 24"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/></svg>
            </div>
            <span class="logo-text">Med<span>Record</span></span>
        </div>
        <nav class="nav">
            <div class="nav-label">Principal</div>
            <a href="{{ path('app_dashboard') }}" class="nav-item">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                Dashboard
            </a>
            <a href="{{ path('medical_record_index') }}" class="nav-item active">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 7V3.5L18.5 9H13zM8 13h8v1.5H8V13zm0 3h8v1.5H8V16zm0-6h5v1.5H8V10z"/></svg>
                Registros Médicos
            </a>
            {% if is_granted('ROLE_ADMIN') %}
            <div class="nav-label">Administración</div>
            <a href="{{ path('admin_index') }}" class="nav-item">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-4z"/></svg>
                Panel Admin
            </a>
            <a href="{{ path('admin_logs') }}" class="nav-item">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg>
                Logs de Auditoría
            </a>
            {% endif %}
        </nav>
        <div class="nav-logout">
            <a href="{{ path('app_logout') }}" class="btn-logout">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4a2 2 0 00-2 2v14a2 2 0 002 2h8v-2H4V5z"/></svg>
                Cerrar Sesión
            </a>
        </div>
    </aside>
    <main class="main">
        <div class="page-header">
            <div>
                <h1>Registros Médicos</h1>
                <p>Gestión de historiales clínicos de pacientes</p>
            </div>
        </div>

        {% if is_granted('ROLE_RECEPTIONIST') and not is_granted('ROLE_NURSE') %}
        <div class="role-banner">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            Acceso limitado — Solo puedes ver datos básicos del paciente. Los detalles médicos están restringidos a tu rol.
        </div>
        {% endif %}

        {% if is_granted('ROLE_NURSE') and not is_granted('ROLE_DOCTOR') %}
        <div class="role-banner">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-4z"/></svg>
            Acceso de enfermería — Puedes ver todos los registros. La eliminación está restringida a administradores.
        </div>
        {% endif %}

        {% if records is empty %}
        <div class="empty-state">
            <div class="empty-icon">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 7V3.5L18.5 9H13zM8 13h8v1.5H8V13zm0 3h8v1.5H8V16zm0-6h5v1.5H8V10z"/></svg>
            </div>
            <h3>No hay registros médicos</h3>
            <p>Aún no se han creado registros en el sistema</p>
        </div>
        {% else %}
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Paciente</th>
                        {% if not (is_granted('ROLE_RECEPTIONIST') and not is_granted('ROLE_NURSE')) %}
                        <th>Doctor</th>
                        <th>Diagnóstico</th>
                        {% endif %}
                        <th>Fecha</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    {% for record in records %}
                    <tr>
                        <td>#{{ record.id }}</td>
                        <td>{{ record.patient.firstName }} {{ record.patient.lastName }}</td>
                        {% if not (is_granted('ROLE_RECEPTIONIST') and not is_granted('ROLE_NURSE')) %}
                        <td>{{ record.doctor.name }}</td>
                        <td>{{ record.diagnosis|slice(0,50) }}...</td>
                        {% endif %}
                        <td>{{ record.createdAt|date('d/m/Y') }}</td>
                        <td>
                            <a href="{{ path('medical_record_show', {id: record.id}) }}" class="btn-ver">Ver</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </main>
</body>
</html>
