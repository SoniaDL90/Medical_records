cat > templates/login/index.html.twig << 'ENDOFFILE'
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedRecord — Acceso Seguro</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{--navy:#0a1628;--teal:#0d9488;--teal-light:#14b8a6;--blue:#1d4ed8;--gray:#94a3b8;--gray-light:#e2e8f0}
        body{font-family:'DM Sans',sans-serif;background:var(--navy);min-height:100vh;display:flex}
        .left-panel{width:55%;background:linear-gradient(135deg,#112240 0%,#0f3460 50%,#16213e 100%);display:flex;flex-direction:column;justify-content:center;align-items:center;padding:4rem;position:relative;overflow:hidden}
        .grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:40px 40px}
        .left-content{position:relative;z-index:1;text-align:center}
        .logo-icon{width:80px;height:80px;background:linear-gradient(135deg,var(--teal),var(--blue));border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 2rem;box-shadow:0 20px 40px rgba(13,148,136,0.3)}
        .logo-icon svg{width:44px;height:44px;fill:white}
        .brand-name{font-family:'DM Serif Display',serif;font-size:3rem;color:white;letter-spacing:-1px;margin-bottom:.5rem}
        .brand-name span{color:var(--teal-light)}
        .brand-tagline{color:var(--gray);font-size:1rem;margin-bottom:3rem}
        .features{display:flex;flex-direction:column;gap:1rem;width:100%;max-width:360px}
        .feature-card{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:1rem 1.25rem;display:flex;align-items:center;gap:1rem}
        .feature-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .feature-icon.teal{background:rgba(13,148,136,0.2);color:var(--teal-light)}
        .feature-icon.blue{background:rgba(29,78,216,0.2);color:#3b82f6}
        .feature-icon.purple{background:rgba(139,92,246,0.2);color:#a78bfa}
        .feature-text h4{color:white;font-size:.875rem}
        .feature-text p{color:var(--gray);font-size:.75rem;margin-top:2px}
        .right-panel{width:45%;background:#f8fafc;display:flex;align-items:center;justify-content:center;padding:3rem}
        .login-box{width:100%;max-width:380px}
        .login-header{margin-bottom:2.5rem}
        .login-header h2{font-family:'DM Serif Display',serif;font-size:2rem;color:var(--navy);margin-bottom:.5rem}
        .login-header p{color:var(--gray);font-size:.9rem}
        .alert-error{background:#fef2f2;border:1px solid #fecaca;border-left:4px solid #ef4444;border-radius:8px;padding:.875rem 1rem;color:#991b1b;font-size:.875rem;margin-bottom:1.5rem}
        .form-group{margin-bottom:1.25rem}
        .form-group label{display:block;font-size:.8rem;font-weight:600;color:var(--navy);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.5rem}
        .input-wrapper{position:relative}
        .input-icon{position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--gray);width:18px;height:18px}
        .form-control{width:100%;padding:.875rem 1rem .875rem 2.75rem;border:1.5px solid var(--gray-light);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:.95rem;color:var(--navy);background:white;outline:none;transition:all .2s}
        .form-control:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(13,148,136,0.1)}
        .btn-login{width:100%;padding:.9rem;background:linear-gradient(135deg,var(--teal),var(--blue));color:white;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;margin-top:.5rem;box-shadow:0 4px 15px rgba(13,148,136,0.3)}
        .btn-login:hover{transform:translateY(-1px);box-shadow:0 8px 25px rgba(13,148,136,0.4)}
        .security-badge{display:flex;align-items:center;justify-content:center;gap:.5rem;margin-top:1.5rem;color:var(--gray);font-size:.78rem}
        .divider{border:none;border-top:1px solid var(--gray-light);margin:1.5rem 0}
        .roles-info{background:#f0fdfa;border:1px solid #99f6e4;border-radius:8px;padding:.875rem 1rem;font-size:.78rem;color:#0f766e}
        .roles-info strong{display:block;margin-bottom:.25rem;color:var(--navy)}
    </style>
</head>
<body>
    <div class="left-panel">
        <div class="grid-bg"></div>
        <div class="left-content">
            <div class="logo-icon">
                <svg viewBox="0 0 24 24"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/></svg>
            </div>
            <h1 class="brand-name">Med<span>Record</span></h1>
            <p class="brand-tagline">Sistema Hospitalario de Gestión Segura</p>
            <div class="features">
                <div class="feature-card">
                    <div class="feature-icon teal">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-4z"/></svg>
                    </div>
                    <div class="feature-text"><h4>Control de Acceso por Roles</h4><p>Médicos, enfermeros, recepción y admin</p></div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon blue">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/></svg>
                    </div>
                    <div class="feature-text"><h4>Auditoría Completa</h4><p>Registro de todos los accesos</p></div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon purple">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    </div>
                    <div class="feature-text"><h4>JWT y Cifrado</h4><p>API REST segura con tokens</p></div>
                </div>
            </div>
        </div>
    </div>
    <div class="right-panel">
        <div class="login-box">
            <div class="login-header">
                <h2>Bienvenido</h2>
                <p>Accede con tus credenciales hospitalarias</p>
            </div>
            {% if error %}
            <div class="alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}
            <form action="{{ path('app_login') }}" method="post">
                <div class="form-group">
                    <label>Correo electrónico</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <input type="email" name="_username" class="form-control" value="{{ last_username }}" placeholder="usuario@hospital.com" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Contraseña</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        <input type="password" name="_password" class="form-control" placeholder="••••••••" required>
                    </div>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn-login">Iniciar Sesión</button>
            </form>
            <div class="security-badge">🔒 Conexión cifrada · RGPD compliant</div>
            <hr class="divider">
            <div class="roles-info">
                <strong>Usuarios de prueba:</strong>
                admin@hospital.com / doctor@hospital.com — Password123!
            </div>
        </div>
    </div>
</body>
</html>
ENDOFFILE
